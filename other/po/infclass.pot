#: src/game/server/infclass/ic_gamecontroller.cpp:6822
msgctxt "White hole"
msgid "White hole pulls the infected into its center."
msgstr ""

#: src/game/server/infclass/ic_gamecontroller.cpp:6824
msgctxt "White hole"
