#: src/game/server/infclass/ic_gamecontroller.cpp:4437
msgid "Rules of the game"
msgstr "Regras do jogo"

#: src/game/server/infclass/ic_gamecontroller.cpp:4439
msgid "InfectionClass is a team game between humans and the infected."
msgstr "InfectionClass é um jogo de equipe entre os humanos e os infectados."

#: src/game/server/infclass/ic_gamecontroller.cpp:4441
msgid "All players start as a human."
msgstr "Todos os jogadores começam como humanos."

#: src/game/server/infclass/ic_gamecontroller.cpp:4443
msgid "10 seconds later, a few players become infected."
msgstr "Passados 10 segundos, alguns jogadores são infectados."

#: src/game/server/infclass/ic_gamecontroller.cpp:4445
msgid "The goal for the humans is to survive until the army cleans the map."
msgstr "O objetivo dos humanos é sobreviver até que o exército limpe o mapa."

#: src/game/server/infclass/ic_gamecontroller.cpp:4447
msgid "The goal for the infected is to infect all humans."
msgstr "O objectivo dos infectados é infectar todos os seres humanos."

#: src/game/server/infclass/ic_gamecontroller.cpp:4449
msgid "See also `/help pages`"
msgstr "Veja também `/help pages`"

#: src/game/server/infclass/ic_gamecontroller.cpp:4454
msgid "How to translate the mod"
msgstr "Como traduzir o mod"

#: src/game/server/infclass/ic_gamecontroller.cpp:4456
msgid "Create an account on Crowdin and join the translation team:"
msgstr "Crie uma conta no Crowdin e junte-se à equipe de tradução:"

#: src/game/server/infclass/ic_gamecontroller.cpp:4463
msgid "White hole"
msgstr "Buraco branco"

#: src/game/server/infclass/ic_gamecontroller.cpp:4465
msgctxt "White hole"
msgid "White hole pulls the infected into its center."
msgstr "Buraco branco puxa o infectado para dentro de seu centro."

#: src/game/server/infclass/ic_gamecontroller.cpp:4469
#, fuzzy
msgctxt "White hole"
msgid "Receive it by killing at least {int:NumKills} infected as a Scientist."
msgid_plural "Receive it by killing at least {int:NumKills} of the infected as a Scientist."
msgstr[0] "Receba-o matando pelo menos um infectado como Cientista."
msgstr[1] "Receba matando pelo menos {int:NumKills} do infectado como Cientista."

#: src/game/server/infclass/ic_gamecontroller.cpp:4473
msgctxt "White hole"
msgid "Use the laser rifle to place it."
msgstr "Use o rifle laser para colocá-lo."

#: src/game/server/infclass/ic_gamecontroller.cpp:4478
msgid "Targeted chat messages"
msgstr "Mensagens de bate-papo alvo"

#: src/game/server/infclass/ic_gamecontroller.cpp:4481
msgid "Use “/w <PlayerName> <My Message>” to send a private message to this player."
msgstr "Use \"/w <NickDoJogador> <Sua Mensagem>\" para enviar uma mensagem privada para este jogador."

#: src/game/server/infclass/ic_gamecontroller.cpp:4483
msgid "Use “/msg !<ClassName> <My Message>” to send a private message to all players with a specific class."
msgstr "Use “/msg !<NomeDaClasse> <Sua Mensagem>” para enviar uma mensagem privada a todos os jogadores com uma classe específica."

#: src/game/server/infclass/ic_gamecontroller.cpp:4485
msgid "Example: “/msg !medic I'm wounded!”"
msgstr "Exemplo: \"/msg !medic estou ferido!\""

#: src/game/server/infclass/ic_gamecontroller.cpp:4487
msgid "Use “/msg !near” to send a private message to all players near you."
msgstr "Use “/msg !near” para enviar uma mensagem privada a todos os jogadores próximos de você."

#: src/game/server/infclass/ic_gamecontroller.cpp:4492
msgid "Persistent player mute"
msgstr "Silenciar jogador"

#: src/game/server/infclass/ic_gamecontroller.cpp:4495
msgid "Use “/mute <PlayerName>” to mute this player."
msgstr "Use “/mute <NickDoJogador>” para silenciar este jogador."

#: src/game/server/infclass/ic_gamecontroller.cpp:4497
msgid "Unlike a client mute this will persist between map changes and wears off when either you or the muted player disconnects."
msgstr "Quando o jogador estiver mutado isso persistirá entre as mudanças de mapa e desaparecerá quando você ou o jogador se desconectar."

#: src/game/server/infclass/ic_gamecontroller.cpp:4499
msgid "Example: “/mute nameless tee”"
msgstr "Exemplo: \"/mute (nick)\""

#: src/game/server/infclass/ic_gamecontroller.cpp:4505
msgid "How to use taxi mode"
msgstr "Como usar o modo taxi"

#: src/game/server/infclass/ic_gamecontroller.cpp:4507
msgid "Two or more humans can form a taxi."
msgstr "Dois ou mais humanos podem formar um táxi."

#: src/game/server/infclass/ic_gamecontroller.cpp:4509
msgid "In order to use it, both humans have to disable hook protection (usually, with F3). The human being hooked becomes the driver."
msgstr "Para usá-lo, ambos os humanos devem desativar a proteção de hook (geralmente, com F3). O jogador que usou o gancho se torna o motorista."

#: src/game/server/infclass/ic_gamecontroller.cpp:4511
msgid "To get off the taxi, jump. To drop off your passengers, enable hook protection (usually, with F3)."
msgstr "Para sair do táxi, pule. Para soltar seus passageiros, ative a proteção de gancho (normalmente, com F3)."

#: src/game/server/infclass/ic_gamecontroller.cpp:4516
msgid "Fast round"
msgstr "Rodada rápida"

#: src/game/server/infclass/ic_gamecontroller.cpp:4519
msgid "In the fast rounds *more* humans become infected initially, the spawning rate is increased and the round time limit is decreased. White hole is also disabled."
msgstr "Nas rodadas rápidas *mais* humanos são infectados inicialmente, a taxa de spawn é aumentada e o limite de tempo de rodada é reduzido. Buraco branco também está desabilitado."

#: src/game/server/infclass/ic_gamecontroller.cpp:4588
msgctxt "Mercenary"
msgid "The Mercenary can fly in the air using their machine gun."
msgstr "O Mercenário pode voar no ar usando sua pistola."

#: src/game/server/infclass/ic_gamecontroller.cpp:4589
msgctxt "Mercenary"
msgid "They can also create a powerful bomb with their hammer that can be charged by hitting it or with a laser rifle."
msgstr "Eles também podem criar uma bomba poderosa com o seu martelo que pode ser carregada ao acertá-la ou com o rifle laser."

#: src/game/server/infclass/ic_gamecontroller.cpp:4593
#, fuzzy
msgctxt "Mercenary"
msgid "Mercenary can also throw poison grenades that deal {int:NumDamagePoints} damage point and prevent the infected from healing."
msgid_plural "Mercenary can also throw poison grenades that deal {int:NumDamagePoints} damage points and prevent the infected from healing."
msgstr[0] "Mercenário também pode lançar granadas venenosas que causam um ponto de dano e bloqueiam a cura dos infectados."
msgstr[1] "Mercenário também pode lançar granadas venenosas que causam {int:NumDamagePoints} pontos de dano e bloqueiam a cura dos infectados."

#: src/game/server/infclass/ic_gamecontroller.cpp:4601
msgctxt "Medic"
msgid "The Medic can protect humans with the hammer by giving them armor."
msgstr "O Médico pode proteger os humanos com o martelo dando-lhes armadura."

#: src/game/server/infclass/ic_gamecontroller.cpp:4602
msgctxt "Medic"
msgid "Grenades with medicine give armor to everybody in their range, including Heroes and the Medic themself."
msgstr "Granadas com medicina dão armaduras a todos no seu alcance, incluindo Heróis e o próprio Médico."

#: src/game/server/infclass/ic_gamecontroller.cpp:4607
msgctxt "Medic"
msgid "Tranqulizer rifle makes the infected fall asleep for {sec:Duration}."
msgstr ""

#: src/game/server/infclass/ic_gamecontroller.cpp:4611
msgctxt "Medic"
msgid "Laser rifle revives the infected, but at the cost of 17 hp and armor."
msgstr "Com o Laser, é possível reviver um infectado, o custo é 17 Hp e Armadura."

#: src/game/server/infclass/ic_gamecontroller.cpp:4613
msgctxt "Medic"
msgid "Medic also has a powerful shotgun that can knock back the infected."
msgstr "Médico também tem uma espingarda poderosa que pode empurrar os infectados."

#: src/game/server/infclass/ic_gamecontroller.cpp:4616
msgctxt "Hero"
msgid "The Hero has all standard weapons."
msgstr "O Herói tem todas as armas normais."

#: src/game/server/infclass/ic_gamecontroller.cpp:4617
msgctxt "Hero"
msgid "The Hero has to find a flag only visible to them. Stand still to be pointed towards it."
msgstr "O Herói tem que encontrar uma bandeira visível apenas para ele. Fique parado para ser apontado para ele."

#: src/game/server/infclass/ic_gamecontroller.cpp:4618
msgctxt "Hero"
msgid "The flag gifts a health point, {int:NumArmorGift} armor and full ammo to all humans."
msgstr "A bandeira dá um ponto de vida, {int:NumArmorGift} armadura e munição completa para todos os humanos."

#: src/game/server/infclass/ic_gamecontroller.cpp:4620
msgctxt "Hero"
msgid "It fully heals the Hero and it can grant a turret which you can place down with the hammer."
msgstr "Ele cura totalmente o Herói e pode conceder uma torre que você pode colocar com o martelo."

#: src/game/server/infclass/ic_gamecontroller.cpp:4621
msgctxt "Hero"
msgid "The gift to all humans is only applied when the flag is surrounded by hearts and armor."
msgstr "O presente para todos os seres humanos só é aplicado quando a bandeira esta cercada por corações e armaduras."

#: src/game/server/infclass/ic_gamecontroller.cpp:4622
msgctxt "Hero"
msgid "The Hero cannot be healed by a Medic, but it can withstand a hit from an infected."
msgstr "O Herói não pode ser curado por um Medico, mas pode resistir a um acerto de um infectado."

#: src/game/server/infclass/ic_gamecontroller.cpp:4625
msgctxt "Engineer"
msgid "The Engineer can build walls with the hammer to block the infected."
msgstr "O Engenheiro pode construir paredes com o martelo para bloquear o infectado."

#: src/game/server/infclass/ic_gamecontroller.cpp:4626
msgctxt "Engineer"
msgid "When an infected touches the wall, it dies."
msgstr "Quando um infectado toca a parede, ele morre."

#: src/game/server/infclass/ic_gamecontroller.cpp:4627
msgctxt "Engineer"
msgid "The lifespan of a wall is {sec:LifeSpan}, and walls are limited to one per player at the same time."
msgstr "A vida útil de uma parede é {sec:LifeSpan}, e as paredes estão limitadas a um por jogador ao mesmo tempo."

#: src/game/server/infclass/ic_gamecontroller.cpp:4632
msgctxt "Soldier"
msgid "The Soldier creates floating bombs with the hammer."
msgstr "O Soldado cria bombas flutuantes com o martelo."

#: src/game/server/infclass/ic_gamecontroller.cpp:4635
#, fuzzy
msgctxt "Soldier"
msgid "Each bomb can explode {int:NumBombs} time."
msgid_plural "Each bomb can explode {int:NumBombs} times."
msgstr[0] "Cada bomba pode explodir uma vez."
msgstr[1] "Cada bomba pode explodir {int:NumBombs} vezes."

#: src/game/server/infclass/ic_gamecontroller.cpp:4639
msgid "Use the hammer to place the bomb and explode it multiple times."
msgstr "Use o martelo para colocar a bomba e explodi-la várias vezes."

#: src/game/server/infclass/ic_gamecontroller.cpp:4642
msgctxt "Ninja"
msgid "The Ninja can throw flash grenades that can freeze the infected for three seconds."
msgstr "O Ninja pode arremessar granadas, que congelam os infectados por três segundos."

#: src/game/server/infclass/ic_gamecontroller.cpp:4647
msgctxt "Ninja"
msgid "Their hammer is replaced with a katana, allowing them to dash {int:NinjaJump} time before touching the ground."
msgid_plural "Their hammer is replaced with a katana, allowing them to dash {int:NinjaJump} times before touching the ground."
msgstr[0] "O martelo deles é substituído por um katana, permitindo-lhes correr {int:NinjaJump} vez antes de tocar o chão."
msgstr[1] "Seu martelo é substituído por um katana, permitindo-lhes correr {int:NinjaJump} vezes antes de tocar o chão."

#: src/game/server/infclass/ic_gamecontroller.cpp:4652
msgid "They also have a laser rifle that blinds the target for a short period of time."
msgstr "Também têm um rifle laser que cega o alvo por um curto período de tempo."

#: src/game/server/infclass/ic_gamecontroller.cpp:4653
msgid "Ninja gets special targets. For killing a target, extra points and abilities are awarded."
msgstr "Ninja obtém alvos especiais. Ao matar um alvo, pontos extras e habilidades são concedidas."

#: src/game/server/infclass/ic_gamecontroller.cpp:4657
msgctxt "Sniper"
msgid "The Sniper can lock the position in mid-air for 15 seconds with the hammer."
msgstr "O Sniper pode se prender no meio do ar por 15 segundos com o martelo."

#: src/game/server/infclass/ic_gamecontroller.cpp:4659
#, fuzzy
msgctxt "Sniper"
msgid "The locked position increases the Sniper's rifle damage from usual 10-13 to 30 damage points."
msgstr "A posição travada aumenta o dano do rifle do Sniper de 10-13 para 20 pontos de dano."

#: src/game/server/infclass/ic_gamecontroller.cpp:4661
msgctxt "Sniper"
msgid "They can also jump two times in the air."
msgstr "Eles também podem pular duas vezes no ar."

#: src/game/server/infclass/ic_gamecontroller.cpp:4664
msgctxt "Scientist"
msgid "The Scientist can pose floating mines with the hammer."
msgstr "O Cientista pode colocar minas flutuantes com o martelo."

#: src/game/server/infclass/ic_gamecontroller.cpp:4667
#, fuzzy
msgctxt "Scientist"
msgid "Mines are limited to {int:NumMines} per player at the same time."
msgid_plural "Mines are limited to {int:NumMines} per player at the same time."
msgstr[0] "Minas estão limitadas a um por jogador ao mesmo tempo."
msgstr[1] "Minas estão limitadas a {int:NumMines} por jogador ao mesmo tempo."

#: src/game/server/infclass/ic_gamecontroller.cpp:4670
msgctxt "Scientist"
msgid "Scientist has also grenades that teleport them."
msgstr "O cientista também tem granadas que as teletransportam."

#: src/game/server/infclass/ic_gamecontroller.cpp:4671
msgctxt "Scientist"
msgid "A lucky Scientist devoted to killing can get a white hole that sucks the infected in which can be placed with the laser rifle."
msgstr "Um cientista dedicado a matar, consegue ter um buraco branco que suga o infectado no qual pode ser colocado com o rifle laser."

#: src/game/server/infclass/ic_gamecontroller.cpp:4675
msgctxt "Biologist"
msgid "The Biologist has a shotgun with bouncing bullets and can create a spring laser trap by shooting with the laser rifle."
msgstr "O Biólogo tem uma espingarda com balas saltitantes e pode criar uma armadilha de laser ao atirar com o rifle laser."

#: src/game/server/infclass/ic_gamecontroller.cpp:4677
msgctxt "Biologist"
msgid "They are also immune to continuous poison effect, and can stop it on teammates with the Hammer."
msgstr ""

#: src/game/server/infclass/ic_gamecontroller.cpp:4681
msgctxt "Looper"
msgid "The Looper has a laser wall that slows down the infected and a low-range laser rifle with a high fire rate."
msgstr "O Looper tem uma parede laser que consegue atrasar o infectado e um rifle laser de baixo alcance com uma alta taxa de tiro."

#: src/game/server/infclass/ic_gamecontroller.cpp:4683
msgctxt "Looper"
msgid "They can also jump two times in the air."
msgstr "Eles também podem pular duas vezes no ar."

#: src/game/server/infclass/ic_gamecontroller.cpp:4686
msgctxt "Smoker"
msgid "Smoker has a powerful hook that hurts humans and sucks their blood, restoring the Smoker's health."
msgstr "O Smoker tem um gancho poderoso que machuca os humanos e suga o seu sangue, restaurando a sua saúde."

#: src/game/server/infclass/ic_gamecontroller.cpp:4688
msgctxt "Smoker"
msgid "It can also infect humans and heal the infected with the hammer."
msgstr "Pode também infectar seres humanos e curar os infectados com o martelo."

#: src/game/server/infclass/ic_gamecontroller.cpp:4691
msgctxt "Boomer"
msgid "The Boomer explodes when it attacks."
msgstr "O Boomer explode quando ataca."

#: src/game/server/infclass/ic_gamecontroller.cpp:4692
msgctxt "Boomer"
msgid "All humans affected by the explosion become infected."
msgstr "Todos os humanos afetados pela explosão são infectados."

#: src/game/server/infclass/ic_gamecontroller.cpp:4693
msgctxt "Boomer"
msgid "It can also inflict 1 damage point per second by hooking humans."
msgstr "Também pode causar 1 ponto de dano por segundo ao segurar os humanos."

#: src/game/server/infclass/ic_gamecontroller.cpp:4696
msgctxt "Hunter"
msgid "The Hunter can jump two times in the air and has some resistance to knock-backs."
msgstr "O Caçador pode pular duas vezes no ar e tem alguma resistência a repulsões."

#: src/game/server/infclass/ic_gamecontroller.cpp:4698
msgctxt "Hunter"
msgid "It can infect humans and heal the infected with the hammer."
msgstr "Pode infectar seres humanos e curar os infectados com o martelo."

#: src/game/server/infclass/ic_gamecontroller.cpp:4699
msgctxt "Hunter"
msgid "It can also inflict 1 damage point per second by hooking humans."
msgstr "Também pode causar 1 ponto de dano por segundo ao segurar os humanos."

#: src/game/server/infclass/ic_gamecontroller.cpp:4702
msgctxt "Bat"
msgid "Bat can jump endlessly in the air but it cannot infect humans."
msgstr "Morcego consegue pular infinitamente, mas não pode infectar humanos."

#: src/game/server/infclass/ic_gamecontroller.cpp:4703
#, fuzzy
msgctxt "Bat"
msgid "Instead, it can hammer humans to steal their health and heal itself."
msgstr "Em vez disso, pode martelar os seres humanos para reduzirem a sua saúde ou mesmo matá-los."

#: src/game/server/infclass/ic_gamecontroller.cpp:4704
msgctxt "Bat"
msgid "The hammer is also useful for healing the infected."
msgstr "O martelo também é útil para curar os infectados."

#: src/game/server/infclass/ic_gamecontroller.cpp:4705
#, fuzzy
msgctxt "Bat"
msgid "It can also inflict 1 damage point per second by hooking humans."
msgstr "Também pode causar 1 ponto de dano por segundo ao segurar os humanos."

#: src/game/server/infclass/ic_gamecontroller.cpp:4708
msgctxt "Ghost"
msgid "The Ghost is invisible until a human comes nearby, it takes damage, or it uses the hammer."
msgstr "O Canibal fica invisível até que um humano chegue perto, sofra dano ou use o martelo."

#: src/game/server/infclass/ic_gamecontroller.cpp:4710
msgctxt "Ghost"
msgid "It can infect humans and heal the infected with the hammer."
msgstr "Pode infectar seres humanos e curar os infectados com o martelo."

#: src/game/server/infclass/ic_gamecontroller.cpp:4711
msgctxt "Ghost"
msgid "It can also inflict 1 damage point per second by hooking humans."
msgstr "Também pode causar 1 ponto de dano por segundo ao segurar os humanos."

#: src/game/server/infclass/ic_gamecontroller.cpp:4714
msgctxt "Spider"
msgid "The Spider has a web hook that automatically grabs any human touching it."
msgstr "A Aranha tem um modo gancho que automaticamente agarra qualquer ser humano tocando-o."

#: src/game/server/infclass/ic_gamecontroller.cpp:4715
msgctxt "Spider"
msgid "The web hook mode can be toggled by switching the weapon."
msgstr "O modo gancho pode ser alternado ao alternar a arma, com o SCROLL."

#: src/game/server/infclass/ic_gamecontroller.cpp:4716
msgctxt "Spider"
msgid "In both modes the hook inflicts 1 damage point per second and can grab a human for longer."
msgstr "Em ambos os modos, o gancho causa 1 ponto de dano por segundo e pode agarrar um humano por mais tempo."

#: src/game/server/infclass/ic_gamecontroller.cpp:4720
msgctxt "Ghoul"
msgid "The Ghoul can devour anything that has died nearby, which makes it stronger, faster and more resistant."
msgstr "O Canibal pode devorar qualquer coisa que tenha morrido nas proximidades, o que o torna mais forte, mais rápido e mais resistente."

#: src/game/server/infclass/ic_gamecontroller.cpp:4722
msgctxt "Ghoul"
msgid "It digests the fodder over time, going back to the normal state. Some nourishment is also lost on death."
msgstr "Ela digere o tempo para a forragem, voltando ao estado normal. Alguma nutrição também é perdida na morte."

#: src/game/server/infclass/ic_gamecontroller.cpp:4724
msgctxt "Ghoul"
msgid "Ghoul can infect humans and heal the infected with the hammer."
msgstr "Canibal pode infectar seres humanos e curar os infectados com o martelo."

#: src/game/server/infclass/ic_gamecontroller.cpp:4725
msgctxt "Ghoul"
msgid "It can also inflict 1 damage point per second by hooking humans."
msgstr "Também pode causar 1 ponto de dano por segundo ao segurar os humanos."

#: src/game/server/infclass/ic_gamecontroller.cpp:4728
msgctxt "Slug"
msgid "The Slug can make the ground and walls toxic by spreading slime with the hammer."
msgstr "A Lesma pode tornar o chão e as paredes tóxicos espalhando a gosma com o martelo."

#: src/game/server/infclass/ic_gamecontroller.cpp:4729
msgctxt "Slug"
msgid "The slime heals the infected and deals damage to humans."
msgstr "A geleia cura os infectados e causa dano aos humanos."

#: src/game/server/infclass/ic_gamecontroller.cpp:4730
msgctxt "Slug"
msgid "Slug can infect humans and heal the infected with the hammer."
msgstr "Lesma pode infectar seres humanos e curar com o martelo"

#: src/game/server/infclass/ic_gamecontroller.cpp:4731
msgctxt "Slug"
msgid "It can also inflict 1 damage point per second by hooking humans."
msgstr "Também pode causar 1 ponto de dano por segundo ao segurar os humanos."

#: src/game/server/infclass/ic_gamecontroller.cpp:4734
msgctxt "Voodoo"
msgid "The Voodoo does not die immediately when killed but instead enters Spirit mode for a short time."
msgstr "O Vodu não morre imediatamente quando morto, mas entra em modo Espirito por um curto período de tempo."

#: src/game/server/infclass/ic_gamecontroller.cpp:4736
msgctxt "Voodoo"
msgid "While in Spirit mode it cannot be killed. When the time is up it finally dies."
msgstr "Quando o jogador ficar no Modo Espírito, ele não pode ser morto. Quando o tempo acabar ele finalmente morre."

#: src/game/server/infclass/ic_gamecontroller.cpp:4737
msgctxt "Voodoo"
msgid "Voodoo can infect humans and heal the infected with the hammer."
msgstr "Vudu pode infectar seres humanos e curar os infectados com o martelo."

#: src/game/server/infclass/ic_gamecontroller.cpp:4738
msgctxt "Voodoo"
msgid "It can also inflict 1 damage point per second by hooking humans."
msgstr "Também pode causar 1 ponto de dano por segundo ao segurar os humanos."

#: src/game/server/infclass/ic_gamecontroller.cpp:4741
msgctxt "Witch"
msgid "The Witch can provide a spawn point for the infected."
msgstr "A Bruxa pode fornecer um ponto de spawn para os infectados."

#: src/game/server/infclass/ic_gamecontroller.cpp:4742
msgctxt "Witch"
msgid "If the Witch dies, it disappears and is replaced by another class."
msgstr "Se a Bruxa morrer, ela desaparece e é substituída por outra classe."

#: src/game/server/infclass/ic_gamecontroller.cpp:4743
msgctxt "Witch"
msgid "Witch can infect humans and heal the infected with the hammer."
msgstr "A bruxa pode infectar humanos e curar os infectados com o martelo."

#: src/game/server/infclass/ic_gamecontroller.cpp:4744
msgctxt "Witch"
msgid "It can also inflict 1 damage point per second by hooking humans."
msgstr "Também pode causar 1 ponto de dano por segundo ao segurar os humanos."

#: src/game/server/infclass/ic_gamecontroller.cpp:4747
msgctxt "Undead"
msgid "The Undead cannot die. Instead of dying, it gets frozen for 10 seconds."
msgstr "Os Mortos-vivos não podem morrer. Em vez de morrer, ficam congelados por 10 segundos."

#: src/game/server/infclass/ic_gamecontroller.cpp:4748
msgctxt "Undead"
msgid "If an infected heals it, the freeze effect disappears."
msgstr "Se um infectado curar ele, o efeito de congelamento desaparece."

#: src/game/server/infclass/ic_gamecontroller.cpp:4749
msgctxt "Undead"
msgid "Undead can infect humans and heal the infected with the hammer."
msgstr "Mortos-vivos podem infectar seres humanos e curar os infectados com o martelo."

#: src/game/server/infclass/ic_gamecontroller.cpp:4750
msgctxt "Undead"
msgid "It can also inflict 1 damage point per second by hooking humans."
msgstr "Também pode causar 1 ponto de dano por segundo ao segurar os humanos."

