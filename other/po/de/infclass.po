#: src/game/server/infclass/ic_gamecontroller.cpp:4705
msgctxt "Bat"
msgid "The hammer is also useful for healing the infected."
msgstr "Der Hammer wird auch zur Heilung der Erkrankten benutzt."

#: src/game/server/infclass/ic_gamecontroller.cpp:4706
#, fuzzy
msgctxt "Bat"
msgid "It can also inflict 1 damage point per second by hooking humans."
