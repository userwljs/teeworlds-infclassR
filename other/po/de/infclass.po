#: src/game/server/infclass/ic_gamecontroller.cpp:7068
msgctxt "Ghost"
msgid "The Ghost is invisible until a human comes nearby, it takes damage, or it uses the hammer."
msgstr "Der Geist ist unsichtbar, bis ein Überlebender in die Nähe kommt, er Schaden nimmt, oder den Hammer benutzt."

#: src/game/server/infclass/ic_gamecontroller.cpp:7070
