msgctxt "Accounts"
msgid "Use `/register` without arguments to start registration via RCON."
msgstr "使用 `/register`（不带参数）来通过远程控制台开始注册。"

#: src/game/server/gamecontext.cpp:4371
msgctxt "Accounts"
msgid "Use `/register <username> <password>` to register via chat commands."
msgstr "使用 `/register <用户名> <密码>` 来通过聊天框指令注册。"

