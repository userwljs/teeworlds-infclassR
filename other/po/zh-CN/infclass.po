msgid "You have {int:NumTurrets} of {int:MaxTurrets} turrets. Use the hammer to place one."
msgstr "你有 {int:NumTurrets} 个炮塔（最多 {int:MaxTurrets} 个），用锤子放置一个。"

#: src/game/server/infclass/classes/humans/human.cpp:1329
msgid "You don't have a turret to place"
msgstr "你没有炮塔可以放置"

