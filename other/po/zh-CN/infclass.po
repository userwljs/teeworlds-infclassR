msgid "You have infected {str:VictimName}, shame on you!"
msgstr "你使 {str:VictimName} 被感染了，你真可耻！"

#: src/game/server/infclass/ic_gamecontroller.cpp:434
msgid "You have been infected by {str:KillerName}"
msgstr "你被 {str:KillerName} 感染了"

#: src/game/server/infclass/ic_gamecontroller.cpp:438
