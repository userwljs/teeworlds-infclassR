msgid "Mercenary's grenades prevent zombies from healing."
msgstr "雇佣兵的榴弹会阻止感染者回血。"

#: src/game/server/infclass/ic_gamecontroller.cpp:127
msgid "Medic can heal Heroes using the grenade launcher."
msgstr "医生能用榴弹发射器治疗英雄。"

#: src/game/server/infclass/ic_gamecontroller.cpp:128
msgid "Medic and Biologist can use hammer to instantly kill an infected."
msgstr "医生和生物学家可以用锤子来瞬间击杀一个感染者。"

#: src/game/server/infclass/ic_gamecontroller.cpp:129
msgid "Hero can stand still for a short time to be pointed towards the flag."
msgstr "英雄能静止不动一段时间，来获得一个指向旗子的点。"

#: src/game/server/infclass/ic_gamecontroller.cpp:130
msgid "Hero's turrets are great for detecting Ghosts."
msgstr "英雄炮塔对于发现幽灵很有用。"

