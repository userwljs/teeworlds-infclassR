msgid "Player muted. Mute will persist until you or the muted player disconnects."
msgstr "已屏蔽玩家。屏蔽将持续到你或者被屏蔽的玩家断开连接。"

#: src/game/server/gamecontext.cpp:4269
msgid "Player unmuted. You can see their messages again."
msgstr "已解除屏蔽玩家。你能看到他们的消息了。"

#: src/game/server/gamecontext.cpp:4343
msgid "Choose a help page with /help <page>"
msgstr "使用 /help <page> 查看帮助页"

